{
	"name": "miniature-octo-invention",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "pnpm -r run build",
		"watch": "pnpm --filter @rbxts/pathfinding run watch",
		"dev": "pnpm --filter @rbxts-pathfinding/plugin run dev",
		"rojo-build": "pnpm --filter @rbxts/pathfinding run rojo-build",
		"check": "biome check .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13"
	}
}
